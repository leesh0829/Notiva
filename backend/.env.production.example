# App
APP_NAME=Meeting AI API
APP_ENV=prod

# Database (Managed Postgres)
# Example: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=postgresql+psycopg2://<db_user>:<db_password>@<db_host>:5432/<db_name>

# Queue (Managed Redis)
# Example: rediss://default:password@host:6379/0
REDIS_URL=rediss://default:<redis_password>@<redis_host>:6379/0
TASK_ALWAYS_EAGER=false

# Auth
JWT_SECRET_KEY=<generate-a-random-64-char-string>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENABLE_DEV_AUTH_ROUTES=false

# Storage (S3 compatible)
S3_ENDPOINT_URL=https://<s3-endpoint>
S3_ACCESS_KEY=<s3-access-key>
S3_SECRET_KEY=<s3-secret-key>
S3_BUCKET=<bucket-name>
S3_REGION=us-east-1
LOCAL_STORAGE_DIR=.local_s3

# OpenAI
OPENAI_API_KEY=<openai-api-key>
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SEC=60

# RAG / chunk
EMBEDDING_DIM=1536
RAG_TOP_K=4
CHUNK_MAX_CHARS=800
CHUNK_OVERLAP_CHARS=120
QA_MAX_CONTEXT_CHARS=2800
QA_HISTORY_TURNS=3
QA_HISTORY_CHARS_PER_TURN=280
SUMMARY_MAP_CHUNK_CHARS=1800
SUMMARY_MAP_MAX_CHUNKS=12
TRASH_RETENTION_DAYS=7

# Budget (optional)
TOKEN_BUDGET_TOTAL=2000000
MONTHLY_BUDGET_USD=20
PRICE_CHAT_INPUT_PER_1M=0.4
PRICE_CHAT_OUTPUT_PER_1M=1.6
PRICE_EMBEDDING_PER_1M=0.02
PRICE_STT_PER_MINUTE=0.006

# CORS
# Comma-separated list, no trailing slash
# Example: https://your-app.vercel.app,https://www.your-domain.com
CORS_ORIGINS=https://<your-vercel-domain>

