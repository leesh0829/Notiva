APP_NAME=Meeting AI API
APP_ENV=dev
DATABASE_URL=sqlite:///./app.db
REDIS_URL=redis://localhost:6379/0
TASK_ALWAYS_EAGER=true
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENABLE_DEV_AUTH_ROUTES=true

S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=recordings
S3_REGION=us-east-1
LOCAL_STORAGE_DIR=.local_s3

OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SEC=60
EMBEDDING_DIM=1536
RAG_TOP_K=3
CHUNK_MAX_CHARS=700
CHUNK_OVERLAP_CHARS=80
QA_MAX_CONTEXT_CHARS=1600
QA_HISTORY_TURNS=3
QA_HISTORY_CHARS_PER_TURN=280
SUMMARY_MAP_CHUNK_CHARS=1800
SUMMARY_MAP_MAX_CHUNKS=12
TRASH_RETENTION_DAYS=7
TOKEN_BUDGET_TOTAL=2000000
MONTHLY_BUDGET_USD=5
PRICE_CHAT_INPUT_PER_1M=0.4
PRICE_CHAT_OUTPUT_PER_1M=1.6
PRICE_EMBEDDING_PER_1M=0.02
PRICE_STT_PER_MINUTE=0.006

CORS_ORIGINS=*
